# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variables — copy this file to web_dashboard/.env.local
# and fill in real values. .env.local is gitignored; never commit real values.
#
# Next.js only inlines NEXT_PUBLIC_* variables into the browser bundle.
# Anything WITHOUT that prefix is server-only: it can be safely read inside
# web_dashboard/src/app/api/**/route.ts (Route Handlers run on the server,
# same as a small backend-for-frontend), but must never be imported into a
# client component.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public (safe for the browser) ────────────────────────────────────────────

# Used by lib/api.ts. Leave unset in normal dev — an empty value makes every
# API call relative (/api/...), which next.config.mjs proxies to FastAPI.
# Only set this to bypass the proxy (e.g. pointing at a staging backend).
NEXT_PUBLIC_API_URL=

# Supabase project URL and anon key — used by lib/supabase.ts for
# client-side auth. The anon key is designed by Supabase to be public
# (Row Level Security enforces access control server-side).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ── Server-only (Route Handlers under src/app/api/** — NEVER prefix with
#    NEXT_PUBLIC_, and never import these into a client component) ──────────

# Where the Next.js Route Handlers proxy requests to the FastAPI backend.
# Defaults to http://127.0.0.1:8000 in every route.ts if unset.
BACKEND_URL=http://127.0.0.1:8000

# Used only by src/app/api/auth/check-email/route.ts to look up accounts by
# email server-side. This is a real secret — it bypasses Supabase Row Level
# Security. Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Comma-separated list of email addresses that src/app/api/auth/check-email/
# route.ts always reports as "exists" without querying Supabase (e.g. demo/
# test accounts). Not a secret in the credential sense, but keep it out of
# source — it's real-account PII. Leave unset/empty for none.
CHECK_EMAIL_ALLOWED_EMAILS=demo@example.com
