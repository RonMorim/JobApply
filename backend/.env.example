# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables — copy this file to backend/.env and fill in
# real values. backend/.env is gitignored; never commit real secrets there.
#
# Every variable below is loaded and validated in backend/config.py — that
# module is the single source of truth for names, defaults, and which
# variables are required vs. optional. By default (STRICT_CONFIG=false),
# missing required variables only log a loud startup warning; they do not
# crash the server (see backend/config.py::_validate_required_env for why).
# ─────────────────────────────────────────────────────────────────────────────

# Strict startup validation. false (default) = safe for local development —
# missing required vars only warn. true = fail fast — the process crashes
# immediately at startup if a required variable is missing, instead of
# serving traffic in a half-configured state.
#
# PRODUCTION SHOULD SET STRICT_CONFIG=true.
STRICT_CONFIG=false


# ── Required ─────────────────────────────────────────────────────────────────

# Every LLM-driven feature (matching, scoring, tailoring, chat, outreach)
# depends on this. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# At least one of the two below must be set for authenticated endpoints to
# return anything other than HTTP 503.

# Enables the RS256/JWKS flow — use this for a hosted Supabase project.
SUPABASE_URL=https://your-project-ref.supabase.co

# Enables the HS256 fallback — use this for local/self-hosted Supabase.
# Dashboard → Project Settings → API → JWT Settings → JWT Secret.
# Must be the raw signing secret, NOT the anon/service-role key (a key
# starting with "eyJ" is rejected — that's a JWT, not a signing secret).
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── RapidAPI LinkedIn-jobs provider (used by POST /api/jobs/analyze) ───────────
# Required for scrape_linkedin_job() in backend/scrapers/url_router.py.
# Defaults match the subscribed provider, "LinkedIn Job Search API" by
# Fantastic Jobs (a filtered-search endpoint, not a get-by-id lookup — see
# url_router.py for the linkedin_id/time_frame/description_format params).
# All four are swappable via env without a code change if you subscribe to a
# different RapidAPI LinkedIn-jobs listing.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_LINKEDIN_HOST=linkedin-job-search-api.p.rapidapi.com
RAPIDAPI_LINKEDIN_PATH=/active-jb
RAPIDAPI_LINKEDIN_TIME_FRAME=6m

# ── Optional — feature-specific; the app runs fine without these ────────────

# Enables live company-research lookups in agents/matching_engine.py.
# Without it: a labelled fallback ("no external data available") is returned.
TAVILY_API_KEY=your_tavily_api_key_here

# Shared secret the inbound-email webhook checks via the X-Webhook-Secret
# header (backend/api/routes/webhooks.py). Without it: the webhook still
# works but accepts unauthenticated requests (a warning is logged at startup).
EMAIL_WEBHOOK_SECRET=your_webhook_shared_secret_here

# Deployment environment name. Controls CORS origin selection (see
# CORS_ALLOWED_ORIGINS below). Defaults to "development".
#
# PRODUCTION SHOULD SET ENVIRONMENT=production.
# ENVIRONMENT=development

# Comma-separated list of browser origins allowed to call this API.
# Only read (and only required) when ENVIRONMENT=production — in
# development the origin list is a fixed localhost allow-list instead.
# If ENVIRONMENT=production and this is left unset, NO origin is allowed
# (fails closed) and a startup error is logged.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com


# ── Not yet used — reserved for a future infrastructure phase ───────────────
# The app's live datastore is SQLite (backend/jobs.db) as of this writing.
# Nothing in the codebase reads these two yet; they are placeholders for a
# later Postgres/Redis migration. Setting them today has no effect.
# DATABASE_URL=postgresql://user:password@localhost:5432/jobapply
# REDIS_URL=redis://localhost:6379/0
