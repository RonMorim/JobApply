ANTHROPIC_API_KEY=your_anthropic_api_key_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jobapply
REDIS_URL=redis://localhost:6379/0
SUPABASE_URL=your_supabase_project_url_here

# ── Supabase JWT auth (required in production; omit for DEV_MODE) ──────────────
# Copy from Supabase dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── RapidAPI LinkedIn-jobs provider (used by POST /api/jobs/analyze) ───────────
# Required for scrape_linkedin_job() in backend/scrapers/url_router.py.
# RAPIDAPI_LINKEDIN_HOST / RAPIDAPI_LINKEDIN_PATH default to a working provider
# but can be swapped without a code change if you subscribe to a different one.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_LINKEDIN_HOST=linkedin-jobs-search.p.rapidapi.com
RAPIDAPI_LINKEDIN_PATH=/job-details
