# Root .dockerignore — applies to the backend image's build context (repo
# root; see backend/Dockerfile). The frontend image builds with
# web_dashboard/ as its own separate context and has its own .dockerignore.

.git/
.github/
.claude/
.streamlit/

# Frontend — irrelevant to the backend image, and large (node_modules).
web_dashboard/

# Legacy Streamlit reference app (see CLAUDE.md) — not part of the FastAPI
# product the backend image serves.
app.py
orchestrator.py
requirements.txt
tests/
data/
*.md
ui_export_for_design.md

# Root-level one-off scripts — not imported by backend.main.
cleanup_stale_why_ron.py
dev_run_flush.py
rescore_cs.py
test_cv.py

venv/
.venv/
__pycache__/
*.pyc
